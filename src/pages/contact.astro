---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Contact — Owen McCullum";
const description =
  "Inquire with Owen McCullum — documentary & street photographer based in Washington, D.C. Prints, licensing, and editorial assignments.";

const EMAIL = "owenmcc.photo@gmail.com";
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="wrap page">
    <header class="page-head reveal">
      <p class="page-eyebrow">Contact</p>
      <h1 class="page-title">Let's make some frames.</h1>
      <p class="page-lede">
        For prints, licensing, editorial assignments, or just to say hello —
        send a note below. Based in Washington, D.C.; available for work
        throughout the DMV and beyond.
      </p>
    </header>

    <div class="contact-layout">
      <!-- Inquiry form -->
      <form class="inquire reveal" novalidate>
        <p class="inq-eyebrow">Inquire</p>

        <div class="inq-field">
          <label for="inq-name">Name</label>
          <input id="inq-name" name="name" type="text" autocomplete="name" required />
          <span class="inq-err" aria-live="polite"></span>
        </div>

        <div class="inq-field">
          <label for="inq-email">Email</label>
          <input id="inq-email" name="email" type="email" autocomplete="email" required />
          <span class="inq-err" aria-live="polite"></span>
        </div>

        <div class="inq-field">
          <label for="inq-type">I'm inquiring about</label>
          <select id="inq-type" name="type">
            <option value="Print">A print</option>
            <option value="Licensing">Licensing an image</option>
            <option value="Assignment">An editorial assignment</option>
            <option value="General">Something else</option>
          </select>
        </div>

        <div class="inq-field">
          <label for="inq-message">Message</label>
          <textarea id="inq-message" name="message" rows="4" required></textarea>
          <span class="inq-err" aria-live="polite"></span>
        </div>

        {/* honeypot — bots fill this, humans don't */}
        <input
          type="text"
          name="_honey"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
        />

        <button class="inq-submit" type="submit">Send inquiry</button>
        <p class="inq-note">
          Sent straight to Owen's inbox. Prefer to write directly?
          <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
        </p>

        <p class="inq-feedback inq-sent" role="status" hidden>
          Thanks — your inquiry is on its way to Owen. He'll be in touch soon.
        </p>
        <p class="inq-feedback inq-error" role="alert" hidden>
          Something went wrong. Please email
          <a href={`mailto:${EMAIL}`}>{EMAIL}</a> directly.
        </p>
      </form>

      <!-- Details -->
      <aside class="contact-aside">
        <div class="contact-block reveal" style="--d:80ms">
          <p class="ck">Email</p>
          <a class="big" href={`mailto:${EMAIL}`}>{EMAIL}</a>
        </div>
        <div class="contact-block reveal" style="--d:160ms">
          <p class="ck">Elsewhere</p>
          <a class="big" href="https://instagram.com/owenmcc.photo" target="_blank" rel="noopener">
            Instagram → @owenmcc.photo
          </a>
        </div>
        <div class="contact-block reveal" style="--d:240ms">
          <p class="ck">Studio</p>
          <p class="big">Washington, D.C.</p>
          <p>
            Editorial &amp; documentary assignments considered case by case.
            Prints ship worldwide.
          </p>
        </div>
        <div class="contact-block reveal" style="--d:320ms">
          <p class="ck">Shoots</p>
          <a class="big" href="/pricing">Plan a session →</a>
        </div>
        <div class="contact-block reveal" style="--d:400ms">
          <p class="ck">Prints &amp; licensing</p>
          <a class="big" href="/prints">See prints &amp; licensing →</a>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const TO = "owenmcc.photo@gmail.com";

  function initInquire() {
    const form = document.querySelector<HTMLFormElement>(".inquire");
    if (!form || form.dataset.init) return;
    form.dataset.init = "1";

    const name = form.querySelector<HTMLInputElement>("[name=name]")!;
    const email = form.querySelector<HTMLInputElement>("[name=email]")!;
    const message = form.querySelector<HTMLTextAreaElement>("[name=message]")!;
    const typeEl = form.querySelector<HTMLSelectElement>("[name=type]")!;
    const honey = form.querySelector<HTMLInputElement>("[name=_honey]")!;
    const submit = form.querySelector<HTMLButtonElement>(".inq-submit")!;
    const note = form.querySelector<HTMLElement>(".inq-note")!;
    const sent = form.querySelector<HTMLElement>(".inq-sent")!;
    const errorBox = form.querySelector<HTMLElement>(".inq-error")!;
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const setErr = (el: HTMLElement, msg: string) => {
      const wrap = el.closest(".inq-field")!;
      wrap.classList.toggle("invalid", !!msg);
      const err = wrap.querySelector(".inq-err");
      if (err) err.textContent = msg;
    };

    const validate = () => {
      let ok = true;
      if (!name.value.trim()) {
        setErr(name, "Please enter your name.");
        ok = false;
      } else setErr(name, "");
      if (!emailRe.test(email.value.trim())) {
        setErr(email, "Please enter a valid email.");
        ok = false;
      } else setErr(email, "");
      if (message.value.trim().length < 10) {
        setErr(message, "Tell Owen a little more (10+ characters).");
        ok = false;
      } else setErr(message, "");
      return ok;
    };

    // Clear an error as soon as the visitor fixes that field.
    [name, email, message].forEach((el) =>
      el.addEventListener("input", () => {
        if (el.closest(".inq-field")!.classList.contains("invalid")) validate();
      }),
    );

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorBox.hidden = true;
      // Honeypot tripped → silently pretend success (it's a bot).
      if (honey.value) {
        return;
      }
      if (!validate()) {
        form
          .querySelector<HTMLElement>(".inq-field.invalid input, .inq-field.invalid textarea")
          ?.focus();
        return;
      }

      const original = submit.textContent;
      submit.disabled = true;
      submit.textContent = "Sending…";

      try {
        const res = await fetch(`https://formsubmit.co/ajax/${TO}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            name: name.value.trim(),
            email: email.value.trim(),
            "inquiring about": typeEl.value,
            message: message.value.trim(),
            _subject: `${typeEl.value} inquiry — ${name.value.trim()} (owenmcc.photo)`,
            _template: "table",
            _captcha: "false",
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && (data.success === true || data.success === "true")) {
          // Replace the form with the success note.
          form
            .querySelectorAll(".inq-field, .inq-submit, .inq-note")
            .forEach((el) => ((el as HTMLElement).hidden = true));
          sent.hidden = false;
        } else {
          throw new Error(data.message || "Request failed");
        }
      } catch {
        errorBox.hidden = false;
        submit.disabled = false;
        submit.textContent = original;
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initInquire, { once: true });
  } else {
    initInquire();
  }
  document.addEventListener("astro:page-load", initInquire);
</script>
