---
import { Image } from "astro:assets";
import { photos, getPhotoImage } from "../data/photos";

// Width hints per layout so Astro emits appropriately-sized, compressed images.
const widthsFor: Record<string, number[]> = {
  feature: [768, 1280, 1900],
  land: [480, 768, 1100],
  port: [400, 640, 900],
};
const sizesFor: Record<string, string> = {
  feature: "(max-width: 860px) 100vw, 1240px",
  land: "(max-width: 860px) 100vw, 600px",
  port: "(max-width: 860px) 100vw, 400px",
};
---

<section class="wrap work" id="work">
  <div class="sec-label">
    <span><b>Selected Work</b></span>
    <span>2025</span>
  </div>
  <div class="grid">
    {
      photos.map((p) => (
        <figure class={`plate c${p.span} s-${p.shape}`} tabindex="0">
          <div class="ph">
            <Image
              src={getPhotoImage(p.file)}
              alt={p.title}
              widths={widthsFor[p.shape]}
              sizes={sizesFor[p.shape]}
              loading="lazy"
            />
          </div>
          <figcaption class="cap">
            <span class="t">{p.title}</span>
            <span>{p.location}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
