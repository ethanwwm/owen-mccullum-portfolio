---
import { series } from "../data/photos";
---

<nav class="chapters" aria-label="Gallery sections" data-chapters>
  <ol class="chapters-list">
    {
      series.map((s, i) => (
        <li>
          <a
            href={`#${s.id}`}
            class={`chapter${i === 0 ? " active" : ""}`}
            data-chapter={s.id}
          >
            <span class="chapter-line" aria-hidden="true" />
            <span class="chapter-idx">{s.index}</span>
            <span class="chapter-title">{s.title}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<script>
  function initChapters() {
    const nav = document.querySelector<HTMLElement>("[data-chapters]");
    const work = document.getElementById("work");
    if (!nav || !work || nav.dataset.init) return;
    nav.dataset.init = "1";

    const links = Array.from(nav.querySelectorAll<HTMLElement>(".chapter"));
    const sections = links
      .map((a) => document.getElementById(a.dataset.chapter!))
      .filter((el): el is HTMLElement => !!el);

    // Smooth-scroll to the section ourselves (bypasses the View Transitions
    // router's hash handling) with an offset for the sticky nav.
    links.forEach((a) => {
      a.addEventListener("click", (e) => {
        const target = document.getElementById(a.dataset.chapter!);
        if (!target) return;
        e.preventDefault();
        const reduce = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        // Offset for the sticky nav, plus the horizontal chapter bar when it's
        // shown (narrow screens); on the wide-screen rail there's no bar.
        const isRail = window.matchMedia("(min-width: 1580px)").matches;
        const header = document.querySelector<HTMLElement>(".site-header");
        const headerH = header ? header.offsetHeight : 78;
        const barH = isRail ? 0 : nav.offsetHeight || 44;
        const offset = headerH + barH + 12;
        const y = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: y, behavior: reduce ? "auto" : "smooth" });
      });
    });

    // Show the rail only while the gallery is on screen (hidden on the
    // slideshow above and the about/footer below). Clear any highlight when
    // the gallery isn't in focus.
    new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          nav.classList.toggle("visible", e.isIntersecting);
          if (!e.isIntersecting)
            links.forEach((a) => a.classList.remove("active"));
        }),
      { threshold: 0 },
    ).observe(work);

    // Highlight the series passing through the middle of the viewport — and
    // clear the highlight entirely once no series is in focus (e.g. in About).
    const inBand = new Set<string>();
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          const id = (e.target as HTMLElement).id;
          if (e.isIntersecting) inBand.add(id);
          else inBand.delete(id);
        });
        let activeId: string | null = null;
        for (const s of sections) {
          if (inBand.has(s.id)) {
            activeId = s.id;
            break;
          }
        }
        links.forEach((a) =>
          a.classList.toggle(
            "active",
            !!activeId && a.dataset.chapter === activeId,
          ),
        );
      },
      { rootMargin: "-45% 0px -50% 0px", threshold: 0 },
    );
    sections.forEach((s) => spy.observe(s));
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initChapters, { once: true });
  } else {
    initChapters();
  }
  document.addEventListener("astro:page-load", initChapters);
</script>
