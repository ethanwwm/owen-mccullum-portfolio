---
import { series } from "../data/photos";
---

<nav class="chapters" aria-label="Gallery sections" data-chapters>
  <ol class="chapters-list">
    {
      series.map((s) => (
        <li>
          <a href={`/work/${s.id}`} class="chapter" data-chapter={s.id}>
            <span class="chapter-line" aria-hidden="true" />
            <span class="chapter-idx">{s.index}</span>
            <span class="chapter-title">{s.title}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<script>
  function initChapters() {
    const nav = document.querySelector<HTMLElement>("[data-chapters]");
    const work = document.getElementById("work");
    if (!nav || !work || nav.dataset.init) return;
    nav.dataset.init = "1";

    // The links now navigate straight to each gallery page, so the rail just
    // needs to appear while the category covers are on screen (hidden over the
    // slideshow above and the about/footer below).
    new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => nav.classList.toggle("visible", e.isIntersecting)),
      { threshold: 0 },
    ).observe(work);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initChapters, { once: true });
  } else {
    initChapters();
  }
  document.addEventListener("astro:page-load", initChapters);
</script>
