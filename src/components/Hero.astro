---
import { Image } from "astro:assets";
import lqip from "../data/lqip.json";
import theBench from "../assets/photos/the-bench.jpg";
import atTheBarricade from "../assets/photos/at-the-barricade.jpg";
import theWord from "../assets/photos/the-word.jpg";
import atTheWall from "../assets/photos/at-the-wall.jpg";
import pastTheFence from "../assets/photos/past-the-fence.jpg";
import theCrossing from "../assets/photos/the-crossing.jpg";
import sky from "../assets/photos/sky.jpg";

const lqipMap = lqip as Record<string, string>;

// A slow cross-dissolve between a handful of the strongest frames — like
// slides advancing in a gallery projection.
const slides = [
  { img: theBench, file: "the-bench.jpg", alt: "Four people seated along a long, low marble bench on a bright stone plaza in hard midday sun, Washington, D.C.", caption: "The Bench · Washington, D.C. — 2025" },
  { img: atTheBarricade, file: "at-the-barricade.jpg", alt: "A bearded man sits behind a white metal crowd-control barricade, gripping one bar, at a public gathering, Washington, D.C.", caption: "At the Barricade · Washington, D.C. — 2025" },
  { img: theWord, file: "the-word.jpg", alt: "A small group stands on a low platform on the snow-covered National Mall in winter, Washington, D.C.", caption: "The Word · Washington, D.C. — 2025" },
  { img: atTheWall, file: "at-the-wall.jpg", alt: "Four young people lie on their backs on a stone plaza at the foot of a massive pale monument wall, Washington, D.C.", caption: "At the Wall · Washington, D.C. — 2025" },
  { img: pastTheFence, file: "past-the-fence.jpg", alt: "Formally dressed people walk a sidewalk at night beside a tall security fence, Washington, D.C.", caption: "Past the Fence · Washington, D.C. — 2025" },
  { img: theCrossing, file: "the-crossing.jpg", alt: "An adult wades through shallow water in a dark cavern, holding a small child's hand.", caption: "The Crossing — 2025" },
  { img: sky, file: "sky.jpg", alt: "A wide expanse of blue sky scattered with soft clouds above a low hilltop, Washington, D.C.", caption: "Sky · Washington, D.C. — 2025" },
];
---

<section class="hero">
  <div class="hero-slides">
    {
      slides.map((s, i) => (
        <div
          class={`hero-slide${i === 0 ? " active" : ""}`}
          data-caption={s.caption}
          style={`background-image:url("${lqipMap[s.file]}")`}
        >
          <Image
            class="blurup"
            src={s.img}
            alt={s.alt}
            widths={[1280, 1920, 2560, 3840]}
            sizes="100vw"
            quality={90}
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "low"}
          />
        </div>
      ))
    }
  </div>

  <div class="hero-bar">
    <figcaption class="hero-cap">{slides[0].caption}</figcaption>
    <div class="hero-controls">
      <button type="button" class="hero-toggle" aria-label="Pause slideshow" aria-pressed="false">
        <svg class="icon-pause" viewBox="0 0 10 12" aria-hidden="true">
          <rect x="0" y="0" width="3" height="12" rx="0.5" />
          <rect x="7" y="0" width="3" height="12" rx="0.5" />
        </svg>
        <svg class="icon-play" viewBox="0 0 10 12" aria-hidden="true">
          <path d="M0.5 0 L10 6 L0.5 12 Z" />
        </svg>
      </button>
      <div class="hero-dots" role="tablist" aria-label="Featured frames">
        {
          slides.map((_, i) => (
            <button
              type="button"
              class={`hero-dot${i === 0 ? " on" : ""}`}
              data-slide={i}
              aria-label={`Show frame ${i + 1}`}
              aria-selected={i === 0 ? "true" : "false"}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  let heroTimer: number | undefined;

  function initHero() {
    const hero = document.querySelector<HTMLElement>(".hero");
    if (!hero || hero.dataset.init) return;
    const slides = Array.from(hero.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(hero.querySelectorAll<HTMLElement>(".hero-dot"));
    const cap = hero.querySelector<HTMLElement>(".hero-cap");
    const toggle = hero.querySelector<HTMLButtonElement>(".hero-toggle");
    if (slides.length < 2) return;
    hero.dataset.init = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const INTERVAL = 4000;
    let cur = 0;
    let playing = false;

    function go(n: number) {
      cur = (n + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle("active", i === cur));
      dots.forEach((d, i) => {
        d.classList.toggle("on", i === cur);
        d.setAttribute("aria-selected", i === cur ? "true" : "false");
      });
      if (cap) {
        cap.style.opacity = "0";
        window.setTimeout(() => {
          cap.textContent = slides[cur].dataset.caption ?? "";
          cap.style.opacity = "1";
        }, 260);
      }
    }

    const stop = () => {
      if (heroTimer) {
        window.clearInterval(heroTimer);
        heroTimer = undefined;
      }
    };
    const play = () => {
      stop();
      playing = true;
      hero.classList.remove("paused");
      toggle?.setAttribute("aria-label", "Pause slideshow");
      toggle?.setAttribute("aria-pressed", "false");
      heroTimer = window.setInterval(() => go(cur + 1), INTERVAL);
    };
    const pause = () => {
      stop();
      playing = false;
      hero.classList.add("paused");
      toggle?.setAttribute("aria-label", "Play slideshow");
      toggle?.setAttribute("aria-pressed", "true");
    };

    toggle?.addEventListener("click", () => (playing ? pause() : play()));
    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        go(i);
        if (playing) play(); // reset the timer on manual selection
      }),
    );
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else if (playing) play();
    });
    document.addEventListener("astro:before-swap", stop, { once: true });

    // Auto-play unless the visitor prefers reduced motion.
    if (reduce) pause();
    else play();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHero, { once: true });
  } else {
    initHero();
  }
  document.addEventListener("astro:page-load", initHero);
</script>
