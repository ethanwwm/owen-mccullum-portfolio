---
import { Image } from "astro:assets";
import hero from "../assets/hero.jpg";
import onTheRail from "../assets/photos/on-the-rail.jpg";
import parked from "../assets/photos/parked.jpg";
import worldpride from "../assets/photos/worldpride.jpg";
import coldSnap from "../assets/photos/cold-snap.jpg";

// A slow cross-dissolve between a handful of the strongest frames — like
// slides advancing in a gallery projection.
const slides = [
  { img: hero, alt: "Inauguration weekend, Washington, D.C.", caption: "Inauguration weekend · Washington, D.C. — 2025" },
  { img: onTheRail, alt: "On the rail, WorldPride", caption: "WorldPride · Washington, D.C. — 2025" },
  { img: parked, alt: "Parked car, Washington, D.C.", caption: "Parked · Washington, D.C. — 2025" },
  { img: worldpride, alt: "WorldPride, Washington, D.C.", caption: "WorldPride · Washington, D.C. — 2025" },
  { img: coldSnap, alt: "Cold snap, Washington, D.C.", caption: "Cold snap · Washington, D.C. — 2025" },
];
---

<section class="hero">
  <div class="hero-slides">
    {
      slides.map((s, i) => (
        <div class={`hero-slide${i === 0 ? " active" : ""}`} data-caption={s.caption}>
          <Image
            src={s.img}
            alt={s.alt}
            widths={[768, 1280, 1900]}
            sizes="100vw"
            quality={80}
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "low"}
          />
        </div>
      ))
    }
  </div>

  <div class="hero-bar">
    <figcaption class="hero-cap">{slides[0].caption}</figcaption>
    <div class="hero-dots" role="tablist" aria-label="Featured frames">
      {
        slides.map((_, i) => (
          <button
            type="button"
            class={`hero-dot${i === 0 ? " on" : ""}`}
            data-slide={i}
            aria-label={`Show frame ${i + 1}`}
            aria-selected={i === 0 ? "true" : "false"}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  let heroTimer: number | undefined;

  function initHero() {
    const hero = document.querySelector<HTMLElement>(".hero");
    if (!hero || hero.dataset.init) return;
    const slides = Array.from(hero.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(hero.querySelectorAll<HTMLElement>(".hero-dot"));
    const cap = hero.querySelector<HTMLElement>(".hero-cap");
    if (slides.length < 2) return;
    hero.dataset.init = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const INTERVAL = 5500;
    let cur = 0;

    const stop = () => {
      if (heroTimer) {
        window.clearInterval(heroTimer);
        heroTimer = undefined;
      }
    };
    const start = () => {
      if (reduce) return;
      stop();
      heroTimer = window.setInterval(() => go(cur + 1), INTERVAL);
    };

    function go(n: number) {
      cur = (n + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle("active", i === cur));
      dots.forEach((d, i) => {
        d.classList.toggle("on", i === cur);
        d.setAttribute("aria-selected", i === cur ? "true" : "false");
      });
      if (cap) {
        cap.style.opacity = "0";
        window.setTimeout(() => {
          cap.textContent = slides[cur].dataset.caption ?? "";
          cap.style.opacity = "1";
        }, 280);
      }
    }

    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        go(i);
        start();
      }),
    );
    hero.addEventListener("mouseenter", stop);
    hero.addEventListener("mouseleave", start);
    document.addEventListener("visibilitychange", () =>
      document.hidden ? stop() : start(),
    );
    document.addEventListener("astro:before-swap", stop, { once: true });

    start();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHero, { once: true });
  } else {
    initHero();
  }
  document.addEventListener("astro:page-load", initHero);
</script>
