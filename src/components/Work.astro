---
import { Image } from "astro:assets";
import { series, photosBySeries, getPhotoImage } from "../data/photos";
import lqip from "../data/lqip.json";

const lqipMap = lqip as Record<string, string>;

// One representative frame per series (its lead photograph) linking through to
// that series' own gallery page.
const covers = series.map((s) => ({ s, cover: photosBySeries(s.id)[0] }));
---

<div class="work" id="work">
  <div class="covers">
    {
      covers.map(({ s, cover }, i) => (
        <a class="cover reveal" href={`/work/${s.id}`} style={`--d:${(i % 2) * 120}ms`}>
          <span class="cover-ph" style={`background-image:url("${lqipMap[cover.file]}")`}>
            <Image
              class="blurup"
              src={getPhotoImage(cover.file)}
              alt={`${s.title} — ${cover.title}`}
              widths={[480, 768, 1100]}
              sizes="(max-width: 860px) 100vw, 620px"
              quality={80}
              loading="lazy"
              decoding="async"
            />
          </span>
          <span class="cover-meta">
            <span class="cover-idx">{s.index}</span>
            <span class="cover-title">{s.title}</span>
            <span class="cover-note">{s.note}</span>
            <span class="cover-cta" aria-hidden="true">View gallery →</span>
          </span>
        </a>
      ))
    }
  </div>
</div>
