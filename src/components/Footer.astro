---
const links = [
  { href: "mailto:opmccullum@gmail.com", label: "opmccullum@gmail.com" },
  { href: "https://instagram.com/owenhowsitgoin", label: "Instagram → @owenhowsitgoin" },
  { href: "/prints", label: "Print & licensing" },
  { href: "/contact", label: "Contact" },
];
---

<footer id="contact">
  <div class="wrap">
    <div class="foot">
      <h2 class="reveal">Let's make<br />some frames.</h2>
      <div class="links reveal" style="--d:140ms">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
    <div class="colophon">
      <span>© 2026 Owen McCullum</span>
      <span>Washington, D.C.</span>
    </div>
  </div>
</footer>
